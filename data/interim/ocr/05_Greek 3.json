        3036.0
      ],
      "confiance": 1.0
    },
    {
      "texte": "read Thucydides), Harl's amazing Teaching Company course on Thucydides, and/or Kagan's book The Peloponnesian War.",
      "texte_balise": "read Thucydides), Harl's amazing Teaching Company course on Thucydides, and/or Kagan's book The Peloponnesian War.",
      "bbox": [
