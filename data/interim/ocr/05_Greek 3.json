        2799.2
      ],
      "confiance": 1.0
    },
    {
      "texte": "If you're super completionist, get an anthology or survey book on pre-Classical Athenian writing. Otherwise just wiki Archaic Greek poetry.",
      "texte_balise": "If you're super completionist, get an anthology or survey book on pre-Classical Athenian writing. Otherwise just wiki Archaic Greek poetry.",
      "bbox": [
        166.0,
